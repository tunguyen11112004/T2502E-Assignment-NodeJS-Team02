
<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Dự án của tôi</h1>
    <p class="text-sm text-gray-500 mt-1">
      Xin chào <span class="font-semibold text-blue-600"><%= user?.fullname || "bạn" %></span>
    </p>
  </div>

  <a href="/api/projects/new">
    <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md shadow transition flex items-center gap-2">
      <span class="text-xl">+</span> Tạo dự án mới
    </button>
  </a>
</div>

<% if (success) { %>
  <div class="mb-4 px-4 py-3 rounded-md bg-green-100 text-green-700 border border-green-200 shadow-sm">
    <%= success %>
  </div>
<% } %>

<% if (error) { %>
  <div class="mb-4 px-4 py-3 rounded-md bg-red-100 text-red-700 border border-red-200 shadow-sm">
    <%= error %>
  </div>
<% } %>

<% if (!projects || projects.length === 0) { %>
  <div class="bg-white p-12 rounded-lg shadow-sm text-center border-2 border-dashed border-gray-200">
    <div class="text-5xl mb-4">📂</div>
    <h3 class="text-lg font-semibold text-gray-700 mb-2">Chưa có dự án nào</h3>
    <p class="text-gray-500 mb-6">Bạn hãy tạo project đầu tiên để bắt đầu quản lý công việc nhé.</p>
    <a href="/api/projects/new" class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md shadow transition">
      Bắt đầu ngay
    </a>
  </div>
<% } %>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% projects.forEach(project => { %>
    <% const isOwner = String(project.owner?._id || project.owner) === String(user?.id || user?._id); %>
    <div class="bg-white p-5 rounded-lg shadow-sm hover:shadow-md transition-all border-t-4 border-blue-500 flex flex-col justify-between">
      <div>
        <div class="flex items-start justify-between gap-3 mb-3">
          <div class="flex-1">
            <h3 class="font-bold text-lg text-gray-800 mb-1 hover:text-blue-600 transition">
              <a href="http://localhost:3000/api/projects/<%= project._id %>/board" class="block">
                <%= project.title %>
              </a> 
            </h3>
            <p class="text-xs text-gray-500">
              Chủ sở hữu: 
              <span class="font-medium text-gray-700">
                <%= project.owner?.fullname || "Không rõ" %>
              </span>
            </p>
          </div>

          <% if (isOwner) { %>
            <span class="text-[10px] font-bold uppercase tracking-wider bg-blue-100 text-blue-700 px-2 py-1 rounded">
              Owner
            </span>
          <% } else { %>
            <span class="text-[10px] font-bold uppercase tracking-wider bg-gray-100 text-gray-600 px-2 py-1 rounded">
              Member
            </span>
          <% } %>
        </div>

        <p class="text-gray-600 text-sm mb-4 line-clamp-2 min-h-[40px]">
          <%= project.description || "Chưa có mô tả cho dự án này." %>
        </p>

        <div class="flex items-center justify-between text-xs text-gray-400 mb-4 border-b border-gray-50 pb-3">
          <span class="flex items-center gap-1">👥 <%= project.members?.length || 0 %> thành viên</span>
          <span class="flex items-center gap-1">🕒 <%= new Date(project.createdAt).toLocaleDateString("vi-VN") %></span>
        </div>

        <div class="mb-4">
          <p class="text-[10px] font-bold uppercase text-gray-400 mb-2">Thành viên tham gia</p>
          <div class="flex flex-wrap gap-2">
            <% (project.members || []).slice(0, 5).forEach(member => { %>
              <div class="flex items-center gap-1 bg-gray-50 border border-gray-100 rounded-full pr-2 pl-1 py-0.5" title="<%= member.fullname %>">
                <% if (member.avatar) { %>
                  <img src="<%= member.avatar %>" class="w-5 h-5 rounded-full object-cover" />
                <% } else { %>
                  <div class="w-5 h-5 rounded-full bg-blue-400 text-[10px] flex items-center justify-center text-white">
                    <%= member.fullname?.charAt(0) %>
                  </div>
                <% } %>
                <span class="text-[10px] text-gray-600"><%= member.fullname.split(' ').pop() %></span>
              </div>
            <% }) %>
            <% if (project.members?.length > 5) { %>
              <span class="text-[10px] text-gray-400 self-center">+<%= project.members.length - 5 %></span>
            <% } %>
          </div>
        </div>
      </div>

      <% if (isOwner) { %>
        <div class="mt-auto pt-4 flex flex-col gap-2">
          <details class="group border border-yellow-200 rounded-md overflow-hidden">
            <summary class="cursor-pointer list-none px-3 py-2 bg-yellow-50 text-yellow-700 text-sm font-medium flex justify-between items-center group-open:bg-yellow-100 transition">
              <span>✏️ Chỉnh sửa thông tin</span>
              <span class="text-xs transition-transform group-open:rotate-180">▼</span>
            </summary>

            <form action="/api/projects/<%= project._id %>?_method=PATCH" method="POST" class="p-3 space-y-3 bg-white">
              <input type="text" name="title" value="<%= project.title %>" required class="w-full border border-gray-200 rounded px-3 py-1.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
              <textarea name="description" rows="2" class="w-full border border-gray-200 rounded px-3 py-1.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none"><%= project.description %></textarea>
              <button type="submit" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white py-1.5 rounded text-sm font-semibold transition">
                Cập nhật
              </button>
            </form>
          </details>

          <form action="/api/projects/<%= project._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Bạn có chắc muốn xóa dự án này?')">
            <button type="submit" class="w-full border border-red-200 text-red-600 hover:bg-red-50 py-2 rounded text-sm font-medium transition">
              🗑️ Xóa dự án
            </button>
          </form>
        </div>
      <% } else { %>
        <a href="/api/projects/<%= project._id %>/board" class="w-full block text-center bg-gray-100 hover:bg-gray-200 text-gray-700 py-2 rounded text-sm font-medium transition">
          👁️ Xem chi tiết
        </a>
      <% } %>
    </div>
  <% }) %>
</div>

<div class="mb-8 flex items-end justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Dự án của tôi</h1>
    <p class="text-sm text-gray-500 mt-1">
      Xin chào <span class="font-semibold text-blue-600"><%= user && user.fullname ? user.fullname : "bạn" %></span>
    </p>
  </div>
</div>

<% if (success) { %>
  <div class="mb-4 px-4 py-3 rounded-xl bg-green-50 text-green-700 border border-green-200 shadow-sm">
    <%= success %>
  </div>
<% } %>

<% if (error) { %>
  <div class="mb-4 px-4 py-3 rounded-xl bg-red-50 text-red-700 border border-red-200 shadow-sm">
    <%= error %>
  </div>
<% } %>

<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5">
  <% (projects || []).forEach(project => { %>
    <%
      const ownerId = project.owner && project.owner._id ? project.owner._id : project.owner;
      const userId = user && user.id ? user.id : (user && user._id ? user._id : null);
      const isOwner = String(ownerId) === String(userId);
      const coverImage = project.coverImage || ('https://picsum.photos/seed/' + project._id + '/800/400');
    %>

    <a
      href="/api/projects/<%= project._id %>/board"
      class="group block overflow-hidden rounded-2xl bg-[#17191f] border border-white/5 shadow-[0_12px_30px_rgba(0,0,0,0.18)] hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(0,0,0,0.22)] transition-all duration-200"
    >
      <div class="relative h-32 overflow-hidden">
        <img
          src="<%= coverImage %>"
          alt="<%= project.title %>"
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/10 to-transparent"></div>

        <% if (isOwner) { %>
          <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-white/90 text-gray-900">
            Owner
          </span>
        <% } %>
      </div>

      <div class="px-4 py-3">
        <h3 class="text-white text-lg font-semibold truncate">
          <%= project.title %>
        </h3>

        <div class="mt-2 flex items-center justify-between text-xs text-gray-400">
          <span><%= project.members ? project.members.length : 0 %> thành viên</span>
          <span><%= new Date(project.createdAt).toLocaleDateString("vi-VN") %></span>
        </div>
      </div>
    </a>
  <% }) %>

  <a
    href="/api/projects/new"
    class="group flex min-h-[180px] flex-col items-center justify-center rounded-2xl bg-[#22242b] border border-white/5 text-center shadow-[0_12px_30px_rgba(0,0,0,0.18)] hover:-translate-y-1 hover:bg-[#292c35] hover:shadow-[0_18px_40px_rgba(0,0,0,0.22)] transition-all duration-200"
  >
    <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white text-2xl mb-3 group-hover:scale-105 transition">
      +
    </div>
    <p class="text-white text-xl font-semibold">Tạo project mới</p>
    <p class="text-sm text-gray-400 mt-1">Nhấn để bắt đầu một bảng mới</p>
  </a>
</div>

<% if (!projects || projects.length === 0) { %>
  <div class="mt-8 rounded-2xl border border-dashed border-gray-300 bg-white/60 p-10 text-center">
    <div class="text-5xl mb-4">📂</div>
    <h3 class="text-lg font-semibold text-gray-800 mb-2">Chưa có project nào</h3>
    <p class="text-gray-500">Bấm vào thẻ “Tạo project mới” để bắt đầu.</p>
  </div>
<% } %>
<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Dự án của tôi</h1>
    <p class="text-sm text-gray-500 mt-1">
      Xin chào <span class="font-semibold"><%= user?.fullname || "bạn" %></span>
    </p>
  </div>

  <a href="/api/projects/new">
    <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md shadow transition">
      + Tạo dự án mới
    </button>
  </a>
</div>

<% if (success) { %>
  <div class="mb-4 px-4 py-3 rounded-md bg-green-100 text-green-700 border border-green-200">
    <%= success %>
  </div>
<% } %>

<% if (error) { %>
  <div class="mb-4 px-4 py-3 rounded-md bg-red-100 text-red-700 border border-red-200">
    <%= error %>
  </div>
<% } %>

<% if (!projects || projects.length === 0) { %>
  <div class="bg-white p-8 rounded-lg shadow text-center">
    <h3 class="text-lg font-semibold text-gray-700 mb-2">Chưa có dự án nào</h3>
    <p class="text-gray-500 mb-4">Bạn hãy tạo project đầu tiên để bắt đầu nhé.</p>
    <a href="/api/projects/new" class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md shadow transition">
      Tạo dự án
    </a>
  </div>
<% } %>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% projects.forEach(project => { %>
    <% const isOwner = String(project.owner?._id || project.owner) === String(user?.id || user?._id); %>

    <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition border-t-4 border-blue-500">
      <div class="flex items-start justify-between gap-3 mb-3">
        <div class="flex-1">
          <h3 class="font-bold text-lg text-gray-800 mb-1">
            <%= project.title %>
          </h3>
          <p class="text-sm text-gray-500">
            Owner:
            <span class="font-medium text-gray-700">
              <%= project.owner?.fullname || "Không rõ" %>
            </span>
          </p>
        </div>

       <% if (isOwner) { %>
  <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full">
    Owner
  </span>
<% } else { %>
  <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full">
    Member
  </span>
<% } %>
</div>

<!-- 👉 INVITE MEMBER (CHỈ OWNER THẤY) -->
<% if (isOwner) { %>
  <form
    action="/api/projects/<%= project._id %>/invite"
    method="POST"
    class="mb-3 flex gap-2"
  >
    <input
      type="email"
      name="email"
      placeholder="Nhập email để mời..."
      required
      class="flex-1 border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-2 focus:ring-green-500 focus:outline-none"
    />

    <button
      type="submit"
      class="bg-green-600 hover:bg-green-700 text-white px-3 py-2 rounded-md text-sm shadow"
    >
      Mời
    </button>
  </form>
<% } %>

      <p class="text-gray-600 text-sm mb-4 min-h-[48px]">
        <%= project.description || "Chưa có mô tả" %>
      </p>

      <div class="flex items-center justify-between text-xs text-gray-400 mb-4">
        <span>👥 <%= project.members?.length || 0 %> thành viên</span>
        <span>🕒 <%= new Date(project.createdAt).toLocaleDateString("vi-VN") %></span>
      </div>

      <div class="mb-4">
        <p class="text-xs font-semibold text-gray-500 mb-2">Thành viên</p>
        <div class="flex flex-wrap gap-2">
          <% (project.members || []).forEach(member => { %>
            <div class="flex items-center gap-2 bg-gray-50 border rounded-full px-3 py-1">
              <% if (member.avatar) { %>
                <img
                  src="<%= member.avatar %>"
                  alt="<%= member.fullname %>"
                  class="w-6 h-6 rounded-full object-cover"
                />
              <% } else { %>
                <div class="w-6 h-6 rounded-full bg-gray-300"></div>
              <% } %>
              <span class="text-xs text-gray-700"><%= member.fullname %></span>
            </div>
          <% }) %>
        </div>
      </div>

      <% if (isOwner) { %>
        <details class="mb-3 border rounded-md">
          <summary class="cursor-pointer list-none px-3 py-2 bg-yellow-50 text-yellow-700 font-medium rounded-md">
            ✏️ Sửa project
          </summary>

          <form
            action="/api/projects/<%= project._id %>?_method=PATCH"
            method="POST"
            class="p-3 space-y-3"
          >
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Tên dự án
              </label>
              <input
                type="text"
                name="title"
                value="<%= project.title %>"
                required
                class="w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Mô tả
              </label>
              <textarea
                name="description"
                rows="3"
                class="w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              ><%= project.description || "" %></textarea>
            </div>

            <button
              type="submit"
              class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-md shadow transition"
            >
              Lưu thay đổi
            </button>
          </form>
        </details>

        <form
          action="/api/projects/<%= project._id %>?_method=DELETE"
          method="POST"
          onsubmit="return confirm('Bạn có chắc muốn xóa mềm project này không?')"
        >
          <button
            type="submit"
            class="w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md shadow transition"
          >
            🗑️ Xóa project
          </button>
        </form>
      <% } %>
    </div>
  <% }) %>
</div>
<div class="bg-white p-8 rounded-lg shadow-xl border border-gray-100 w-full max-w-md mx-auto">
    <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-gray-800 tracking-tight">Chào mừng trở lại</h2>
        <p class="text-gray-500 text-sm">Đăng nhập để tiếp tục làm việc</p>
    </div>

    <div id="success-msg"
        class="hidden bg-green-50 border-l-4 border-green-500 text-green-700 p-3 mb-4 text-sm rounded shadow-sm">
        Đăng ký tài khoản thành công! Vui lòng đăng nhập.
    </div>

    <% if (error) { %>
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-3 mb-4 text-sm rounded shadow-sm">
            <%= error %>
        </div>
        <% } %>

            <form action="/auth/login" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-600 mb-1">Email</label>
                    <input type="email" name="email" required
                        class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                        placeholder="email@example.com">
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-600 mb-1">Mật khẩu</label>
                    <input type="password" name="password" required
                        class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                        placeholder="••••••••">
                </div>

                <button type="submit"
                    class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2.5 rounded shadow-md transition duration-200 mt-2">
                    Đăng nhập
                </button>
            </form>

            <div class="mt-6 pt-6 border-t border-gray-100 text-center text-sm text-gray-600">
                Chưa có tài khoản?
                <a href="/auth/register" class="text-blue-700 hover:underline font-bold">Tạo tài khoản mới</a>
            </div>
</div>

<script>
    // Logic nhỏ để hiển thị thông báo thành công nếu thấy tham số 'message' trên URL
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('message')) {
        document.getElementById('success-msg').classList.remove('hidden');
    }
</script>
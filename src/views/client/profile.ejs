<div class="max-w-5xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div id="status-alert" class="hidden mb-6 p-4 rounded-lg shadow-sm border-l-4 transition-all"></div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <div class="lg:col-span-1 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-center">
                <div class="relative inline-block group">
                    <img id="avatar-preview" src="<%= userProfile.avatar || '/images/default-avatar.png' %>"
                        alt="Avatar"
                        class="w-32 h-32 rounded-full border-4 border-blue-50 shadow-lg object-cover mx-auto bg-gray-50">

                    <form action="/auth/profile/avatar" method="POST" enctype="multipart/form-data" id="avatarForm">
                        <input type="file" name="avatar" id="avatarInput" class="hidden" accept="image/*">
                        <button type="button" onclick="document.getElementById('avatarInput').click()"
                            class="absolute bottom-1 right-1 bg-blue-600 text-white p-2 rounded-full shadow-lg hover:bg-blue-700 transition transform hover:scale-110">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z">
                                </path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </button>
                    </form>
                </div>

                <div class="mt-4">
                    <h2 class="text-xl font-bold text-gray-800">
                        <%= userProfile.fullname %>
                    </h2>
                    <p class="text-sm text-gray-500">
                        <%= userProfile.email %>
                    </p>
                    <span
                        class="inline-block mt-2 px-3 py-1 bg-blue-50 text-blue-600 text-xs font-bold rounded-full uppercase tracking-wide">
                        <%= userProfile.role || 'Thành viên' %>
                    </span>
                </div>

                <div class="mt-6 pt-6 border-t border-gray-50 flex justify-around text-sm">
                    <div>
                        <p class="font-bold text-gray-800">12</p>
                        <p class="text-gray-400">Dự án</p>
                    </div>
                    <div>
                        <p class="font-bold text-gray-800">45</p>
                        <p class="text-gray-400">Tasks</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-2 space-y-8">

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
                <h3 class="text-lg font-bold text-gray-800 mb-6 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    Thông tin cơ bản
                </h3>

                <form action="/auth/profile/update" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="text-sm font-semibold text-gray-600">Họ và tên</label>
                        <input type="text" name="fullname" value="<%= userProfile.fullname %>"
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition">
                    </div>
                    <div class="space-y-1 opacity-60">
                        <label class="text-sm font-semibold text-gray-600">Email (Không thể đổi)</label>
                        <input type="email" value="<%= userProfile.email %>" readonly
                            class="w-full px-4 py-2.5 border border-gray-100 bg-gray-50 rounded-xl cursor-not-allowed">
                    </div>
                    <div class="md:col-span-2 text-right">
                        <button type="submit"
                            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-xl font-bold transition shadow-md">
                            Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
                <h3 class="text-lg font-bold text-gray-800 mb-6 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z">
                        </path>
                    </svg>
                    Bảo mật & Mật khẩu
                </h3>

                <form action="/auth/profile/change-password" method="POST" class="space-y-4 max-w-md">
                    <div>
                        <input type="password" name="oldPassword" placeholder="Mật khẩu hiện tại" required
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-transparent outline-none transition">
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <input type="password" name="newPassword" placeholder="Mật khẩu mới" required
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-transparent outline-none transition">
                        <input type="password" name="confirmPassword" placeholder="Xác nhận mật khẩu" required
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-transparent outline-none transition">
                    </div>
                    <button type="submit"
                        class="w-full bg-gray-800 hover:bg-black text-white px-6 py-2.5 rounded-xl font-bold transition shadow-lg">
                        Cập nhật mật khẩu mới
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    // 1. Tự động submit khi chọn file Avatar
    const avatarInput = document.getElementById('avatarInput');
    const avatarForm = document.getElementById('avatarForm');

    avatarInput.onchange = () => {
        if (avatarInput.files && avatarInput.files[0]) {
            avatarForm.submit();
        }
    };

    // 2. Hiển thị thông báo trạng thái từ URL params
    const params = new URLSearchParams(window.location.search);
    const alertBox = document.getElementById('status-alert');
    const status = params.get('status');
    const msg = params.get('message');

    if (status && msg) {
        alertBox.classList.remove('hidden');
        if (status === 'success') {
            alertBox.classList.add('bg-green-50', 'text-green-700', 'border-green-500');
            alertBox.innerHTML = `<strong>Thành công!</strong> ${decodeURIComponent(msg)}`;
        } else {
            alertBox.classList.add('bg-red-50', 'text-red-700', 'border-red-500');
            alertBox.innerHTML = `<strong>Lỗi!</strong> ${decodeURIComponent(msg)}`;
        }
        // Tự ẩn sau 5 giây
        setTimeout(() => alertBox.classList.add('opacity-0'), 4000);
        setTimeout(() => alertBox.classList.add('hidden'), 5000);
    }
</script>
<div class="min-h-screen bg-gray-100 p-6">
  <div class="max-w-7xl mx-auto mb-8 flex justify-between items-center">
    <div>
      <nav class="flex text-sm text-gray-500 mb-2">
        <a href="/api/projects" class="hover:text-blue-600">Dự án</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800 font-medium"><%= project.title %></span>
      </nav>
      <h1 class="text-3xl font-extrabold text-gray-900"><%= project.title %></h1>
    </div>
    
    <div class="flex items-center gap-3">
      <div class="flex -space-x-2">
        <% (project.members || []).forEach(member => { %>
          <img src="<%= member.avatar || 'https://ui-avatars.com/api/?name=' + member.fullname %>" 
               class="h-8 w-8 rounded-full border-2 border-white" title="<%= member.fullname %>">
        <% }) %>
      </div>
      <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-bold transition shadow-md">
        Mời thành viên
      </button>
    </div>
  </div>

  <div class="flex gap-6 overflow-x-auto pb-6 items-start">
    <% const columns = [
        { id: 'ToDo', name: 'To Do', color: 'bg-red-500' },
        { id: 'InProgress', name: 'In Progress', color: 'bg-yellow-500' },
        { id: 'Done', name: 'Done', color: 'bg-green-500' }
    ]; %>

    <% columns.forEach(column => { %>
      <div class="w-80 flex-shrink-0 bg-gray-200 rounded-xl shadow-sm border border-gray-300 flex flex-col max-h-[80vh]">
        <div class="p-4 flex justify-between items-center flex-shrink-0">
          <div class="flex items-center gap-2">
            <div class="w-2 h-6 <%= column.color %> rounded-full"></div>
            <h2 class="font-bold text-gray-700 uppercase text-sm tracking-wider"><%= column.name %></h2>
          </div>
        </div>

        <div id="<%= column.id %>" class="task-list p-2 space-y-3 overflow-y-auto flex-grow min-h-[50px]">
          <% (tasks || []).filter(t => t.status === column.id).forEach(task => { %>
            <div data-id="<%= task._id %>" 
                 onclick="openTaskDetail('<%= task._id %>')"
                 class="task-item bg-white p-4 rounded-lg shadow border border-transparent hover:border-blue-400 cursor-grab active:cursor-grabbing transition group relative">
              
              <button onclick="event.stopPropagation(); deleteTask('<%= task._id %>')" 
                      class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 text-gray-300 hover:text-red-500 transition p-1 rounded-full hover:bg-red-50">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>

              <p class="text-sm text-gray-800 font-medium mb-1 pr-6"><%= task.title %></p>
            </div>
          <% }) %>
        </div>

        <div class="p-2 border-t border-gray-300">
          <details class="group">
            <summary class="list-none cursor-pointer p-2 text-gray-600 hover:bg-gray-300 rounded-lg flex items-center gap-2 transition text-sm font-bold font-sans">
              <span class="text-xl">+</span> Thêm một thẻ
            </summary>
            <div class="mt-2 bg-white p-3 rounded-xl shadow-lg border border-blue-200 text-left">
              <form action="/api/tasks/create" method="POST" class="space-y-3">
                <input type="hidden" name="projectId" value="<%= project._id %>">
                <input type="hidden" name="status" value="<%= column.id %>">
                <textarea name="content" required placeholder="Nhập tiêu đề cho thẻ này..." 
                  class="w-full p-3 text-sm border border-gray-200 rounded-lg outline-none focus:ring-2 focus:ring-blue-500 min-h-[80px] shadow-inner"></textarea>
                <div class="flex items-center gap-2">
                  <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded font-bold text-xs hover:bg-blue-700 transition">Thêm thẻ</button>
                  <button type="button" onclick="this.closest('details').open = false" class="text-gray-500 hover:text-gray-800 transition p-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                  </button>
                </div>
              </form>
            </div>
          </details>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<div id="taskModal" class="fixed inset-0 bg-black/60 z-50 hidden flex items-center justify-center p-4 backdrop-blur-sm" onclick="if(event.target === this) closeModal()">
  <div class="bg-[#F4F5F7] rounded-xl shadow-2xl w-full max-w-4xl overflow-hidden transform transition-all border border-gray-100 max-h-[90vh] flex flex-col text-left">
      
      <div class="p-6 pb-2 flex justify-between items-start">
        <div class="flex gap-4 items-start w-full">
            <svg class="w-6 h-6 text-gray-600 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
            <div class="w-full">
                <input type="text" id="modalTaskTitle" class="w-full text-2xl font-bold text-gray-900 bg-transparent p-1 -ml-1 rounded hover:bg-gray-200 focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition" value="Loading...">
                <p class="text-sm text-gray-600 mt-1">trong danh sách <span id="modalColumnName" class="font-medium text-gray-700 underline">...</span></p>
            </div>
        </div>
        <button onclick="closeModal()" class="text-gray-500 hover:text-gray-800 transition p-2 hover:bg-gray-200 rounded-full flex-shrink-0 -mt-2 -mr-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>

      <div class="p-6 flex-grow overflow-y-auto grid grid-cols-1 md:grid-cols-[1fr,240px] gap-8">
          <div class="space-y-8">
              <div class="flex flex-wrap gap-2 pt-1">
                  <button class="flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded text-sm font-medium transition"><span class="text-lg">+</span> Thêm</button>
                  <button class="flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded text-sm font-medium transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg> Nhãn</button>
                  <button class="flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded text-sm font-medium transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Ngày</button>
              </div>

              <div class="space-y-3">
                  <div class="flex justify-between items-center">
                      <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-3">
                        <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg> Mô tả
                      </h3>
                      <button id="btnEditDesc" class="text-sm font-medium text-gray-600 bg-gray-200 hover:bg-gray-300 px-3 py-1.5 rounded transition">Sửa</button>
                  </div>
                  <div id="descView" class="p-4 bg-gray-200 rounded-lg hover:bg-gray-300 cursor-pointer min-h-[80px] transition" onclick="toggleEditDesc()">
                      <p id="txtDesc" class="text-sm text-gray-700">Thêm mô tả chi tiết hơn...</p>
                  </div>
                  <div id="descEdit" class="hidden space-y-3">
                      <textarea id="modalTaskDesc" class="w-full p-4 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none min-h-[150px] text-sm text-gray-800 transition shadow-inner" placeholder="Thêm mô tả chi tiết hơn..."></textarea>
                      <div class="flex items-center gap-2">
                          <button onclick="saveDescription()" class="px-4 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded transition shadow">Lưu</button>
                          <button onclick="toggleEditDesc()" class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 rounded transition">Hủy</button>
                      </div>
                  </div>
              </div>

              <div class="space-y-4">
                  <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-3 mb-2">
                    <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg> Hoạt động & Bình luận
                  </h3>
                  <div class="flex gap-4 items-start pt-2">
                      <img src="https://ui-avatars.com/api/?name=Admin" class="w-9 h-9 rounded-full flex-shrink-0">
                      <div class="w-full bg-white border border-gray-200 rounded-xl shadow-sm focus-within:ring-2 focus-within:ring-blue-300 transition-all overflow-hidden">
                          <textarea id="txtComment" class="w-full p-3 bg-transparent text-sm outline-none resize-none" placeholder="Viết bình luận..." rows="1"></textarea>
                          <div class="px-3 pb-2 flex justify-end">
                            <button id="btnComment" class="px-3 py-1 text-xs font-bold text-gray-500 bg-gray-100 rounded transition cursor-not-allowed" disabled>Bình luận</button>
                          </div>
                      </div>
                  </div>
              </div>
          </div>

          <div class="hidden md:block space-y-4 pt-1">
              <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Hành động</h4>
              <button class="w-full flex items-center gap-2.5 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2.5 rounded text-sm font-medium transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg> Thành viên</button>
              <button onclick="event.stopPropagation(); deleteTask(currentEditingTaskId)" class="w-full flex items-center gap-2.5 bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2.5 rounded text-sm font-semibold transition mt-4"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg> Xóa thẻ</button>
          </div>
      </div>
  </div>
</div>

<style>
  ::-webkit-scrollbar { height: 8px; width: 8px; }
  ::-webkit-scrollbar-track { background: #e2e8f0; border-radius: 10px; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
  .ghost-card { opacity: 0.1; background: #3b82f6 !important; border: 2px dashed #2563eb !important; }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
  let currentEditingTaskId = null;
  const modal = document.getElementById('taskModal');
  const titleInput = document.getElementById('modalTaskTitle');
  const descTextarea = document.getElementById('modalTaskDesc');

  // KÉO THẢ (DRAG & DROP)
  const lists = document.querySelectorAll('.task-list');
  lists.forEach(list => {
    new Sortable(list, {
      group: 'kanban', animation: 150, ghostClass: 'ghost-card',
      onEnd: async function (evt) {
        const taskId = evt.item.getAttribute('data-id');
        const newStatus = evt.to.id;
        if (evt.from !== evt.to) {
          try {
            await fetch('/api/tasks/update-status', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ taskId, newStatus })
            });
          } catch (e) { console.error('Lỗi cập nhật trạng thái'); }
        }
      }
    });
  });

  // MỞ CHI TIẾT TASK
  async function openTaskDetail(taskId) {
    currentEditingTaskId = taskId;
    try {
      const response = await fetch(`/api/tasks/${taskId}`);
      const result = await response.json();
      const task = result.data || result; // Hỗ trợ cả {data: task} và task trực tiếp

      titleInput.value = task.title;
      descTextarea.value = task.description || ""; 
      document.getElementById('txtDesc').innerText = task.description || "Thêm mô tả chi tiết hơn...";
      
      const statusMap = { 'ToDo': 'To Do', 'InProgress': 'In Progress', 'Done': 'Done' };
      document.getElementById('modalColumnName').innerText = statusMap[task.status] || task.status;
      
      modal.classList.remove('hidden');
    } catch (e) { alert('Lỗi lấy chi tiết task'); }
  }

  function closeModal() {
    modal.classList.add('hidden');
    currentEditingTaskId = null;
    hideEditDesc();
  }

  // 1. CẬP NHẬT TIÊU ĐỀ (Title)
  titleInput.addEventListener('blur', async () => {
    const newTitle = titleInput.value;
    try {
      const response = await fetch(`/api/tasks/${currentEditingTaskId}/content`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: newTitle }) // Gửi field 'title' khớp Controller
      });
      if (response.ok) {
        const taskCard = document.querySelector(`[data-id="${currentEditingTaskId}"] p`);
        if (taskCard) taskCard.innerText = newTitle;
      }
    } catch (e) { console.error('Lỗi lưu tiêu đề'); }
  });

  // 2. CẬP NHẬT MÔ TẢ (Description)
  function toggleEditDesc() {
    document.getElementById('descView').classList.add('hidden');
    document.getElementById('descEdit').classList.remove('hidden');
    descTextarea.focus();
  }
  function hideEditDesc() {
    document.getElementById('descView').classList.remove('hidden');
    document.getElementById('descEdit').classList.add('hidden');
  }

  async function saveDescription() {
    const newDesc = descTextarea.value;
    try {
      const response = await fetch(`/api/tasks/${currentEditingTaskId}/description`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ description: newDesc }) // Gửi field 'description' khớp Controller
      });
      if (response.ok) {
        document.getElementById('txtDesc').innerText = newDesc || "Thêm mô tả chi tiết hơn...";
        hideEditDesc();
      }
    } catch (e) { alert('Lỗi lưu mô tả'); }
  }

  // 3. XÓA TASK
  async function deleteTask(taskId) {
    if (confirm('Bạn có chắc muốn xóa thẻ này vĩnh viễn?')) {
      try {
        const response = await fetch(`/api/tasks/${taskId}`, { method: 'DELETE' });
        if (response.ok) {
          const el = document.querySelector(`[data-id="${taskId}"]`);
          if(el) el.remove();
          closeModal();
        }
      } catch (e) { alert('Lỗi xóa'); }
    }
  }

  // UI Comment
  document.getElementById('txtComment').addEventListener('input', e => {
    const btn = document.getElementById('btnComment');
    if (e.target.value.trim().length > 0) {
        btn.disabled = false;
        btn.classList.add('bg-blue-600', 'text-white');
        btn.classList.remove('cursor-not-allowed');
    } else {
        btn.disabled = true;
        btn.classList.remove('bg-blue-600', 'text-white');
        btn.classList.add('cursor-not-allowed');
    }
  });
</script>

<style>
  /* Ẩn thanh cuộn mặc định để nhìn đẹp hơn */
  ::-webkit-scrollbar {
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>
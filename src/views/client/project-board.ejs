<div class="min-h-screen bg-gray-50 p-6">
  <div class="max-w-7xl mx-auto mb-8 flex justify-between items-center">
    <div>
      <nav class="flex text-sm text-gray-500 mb-2">
        <a href="/api/projects" class="hover:text-blue-600">Dự án</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800 font-medium"><%= project.title %></span>
      </nav>
      <h1 class="text-3xl font-extrabold text-gray-900"><%= project.title %></h1>
    </div>
    
    <div class="flex items-center gap-3">
      <div class="flex -space-x-2">
        <% (project.members || []).forEach(member => { %>
          <img src="<%= member.avatar || 'https://ui-avatars.com/api/?name=' + member.fullname %>" 
               class="h-8 w-8 rounded-full border-2 border-white" title="<%= member.fullname %>">
        <% }) %>
      </div>
      <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-bold transition shadow-md">
        Mời thành viên
      </button>
    </div>
  </div>

  <div class="flex gap-6 overflow-x-auto pb-6 items-start">
    
    <% const columns = [
        { id: 'ToDo', name: 'To Do', color: 'bg-red-500' },
        { id: 'InProgress', name: 'In Progress', color: 'bg-yellow-500' },
        { id: 'Done', name: 'Done', color: 'bg-green-500' }
    ]; %>

    <% columns.forEach(column => { %>
      <div class="w-80 flex-shrink-0 bg-gray-100 rounded-xl shadow-sm border border-gray-200">
        <div class="p-4 flex justify-between items-center">
          <div class="flex items-center gap-2">
            <div class="w-2 h-6 <%= column.color %> rounded-full"></div>
            <h2 class="font-bold text-gray-700 uppercase text-sm tracking-wider"><%= column.name %></h2>
          </div>
          <span class="bg-gray-200 text-gray-600 text-xs font-bold px-2 py-1 rounded-full">
            <%= (tasks || []).filter(t => t.status === column.id).length %>
          </span>
        </div>

        <div class="p-2 space-y-3 min-h-[50px]">
          <% (tasks || []).filter(t => t.status === column.id).forEach(task => { %>
            <div class="bg-white p-4 rounded-lg shadow-sm border border-transparent hover:border-blue-400 cursor-grab active:cursor-grabbing transition group relative">
              <p class="text-sm text-gray-800 font-medium mb-3"><%= task.title %></p>
              
              <div class="flex justify-between items-center">
                <span class="text-[10px] text-gray-400">
                  🕒 <%= new Date(task.createdAt).toLocaleDateString("vi-VN") %>
                </span>
                <% if (task.assignee) { %>
                  <img src="<%= task.assignee.avatar %>" class="w-5 h-5 rounded-full">
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="p-2">
          <details class="group">
            <summary class="list-none cursor-pointer p-2 text-gray-500 hover:bg-gray-200 hover:text-gray-700 rounded-lg flex items-center gap-2 transition text-sm font-medium">
              <span class="text-lg">+</span> Thêm một thẻ
            </summary>
            
            <div class="mt-2 bg-white p-3 rounded-lg shadow-md border border-blue-200">
              <form action="/api/tasks/create" method="POST" class="space-y-3">
                <input type="hidden" name="projectId" value="<%= project._id %>">
                <input type="hidden" name="status" value="<%= column.id %>">
                
                <textarea name="content" required placeholder="Nội dung công việc..." 
                  class="w-full p-2 text-sm border border-gray-200 rounded outline-none focus:ring-2 focus:ring-blue-500 min-h-[80px]"></textarea>
                
                <div class="flex items-center gap-2">
                  <button type="submit" class="bg-blue-600 text-white px-3 py-1.5 rounded text-xs font-bold hover:bg-blue-700">
                    Thêm thẻ
                  </button>
                  <button type="reset" class="text-gray-400 hover:text-gray-600 p-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                </div>
              </form>
            </div>
          </details>
        </div>
      </div>
    <% }) %>

  </div>
</div>

<style>
  /* Ẩn thanh cuộn mặc định để nhìn đẹp hơn */
  ::-webkit-scrollbar {
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>
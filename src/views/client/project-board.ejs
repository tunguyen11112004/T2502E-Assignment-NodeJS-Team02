<% const currentUserId=String(user && user.id ? user.id : (user && user._id ? user._id : "" )); // MULTI OWNER SUPPORT
  let isOwner=false; if (project && project.members) { isOwner=project.members.some( m=> String(m.user._id || m.user)
  === currentUserId && m.role === "owner"
  );
  }

  const ownerId = project && project.owner && project.owner._id
  ? String(project.owner._id)
  : String(project.owner || "");
  %>

  <div id="projectBoardPage" data-project-id="<%= project._id %>" data-is-owner="<%= isOwner %>"
    data-current-user-id="<%= currentUserId %>" data-owner-id="<%= ownerId %>" class="min-h-screen bg-gray-100 p-6">

    <%- include('../partials/project-board-header', { project, user, isOwner }) %>

      <%- include('../partials/project-board-columns', { project, taskLists, tasks, isOwner }) %>


  </div>

  <%- include('../partials/project-invite-modal', { project, user, isOwner, currentUserId, ownerId }) %>

    <%- include('../partials/task-detail-modal', { isOwner: isOwner }) %>
      <%- include('../partials/date-picker-modal') %>

        <!-- Trash Modal -->
        <div id="trashModal"
          class="fixed inset-0 z-60 hidden items-center justify-center bg-black/50 p-4 backdrop-blur-sm"
          onclick="if(event.target === this) closeTrashModal()">
          <div class="w-full max-w-4xl bg-white rounded-2xl shadow-2xl overflow-hidden">
            <div class="flex items-center justify-between p-5 border-b border-gray-200">
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Task đã xóa</h3>
                <p class="text-sm text-gray-500">
                  Danh sách các task đã xóa trong dự án này
                </p>
              </div>

              <button type="button" onclick="event.stopPropagation(); closeTrashModal()"
                class="text-gray-500 hover:text-gray-800">
                ✕
              </button>
            </div>

            <div class="p-5">
              <div id="trashTaskList" class="space-y-3 max-h-96 overflow-y-auto">
              </div>
            </div>

          </div>
        </div>

        <style>
          ::-webkit-scrollbar {
            height: 8px;
            width: 8px;
          }

          ::-webkit-scrollbar-track {
            background: #e2e8f0;
            border-radius: 10px;
          }

          ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
          }

          ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
          }

          .ghost-card {
            opacity: 0.1;
            background: #3b82f6 !important;
            border: 2px dashed #2563eb !important;
          }
        </style>

        <link rel="stylesheet" href="/css/project-board.css">

        <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
        <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

        <script src="/js/project-board.js"></script>

        <script>
          document.addEventListener('DOMContentLoaded', function () {
            // 1. Tìm tất cả các danh sách task (nơi chứa các thẻ card)
            const taskLists = document.querySelectorAll('.task-list'); 

            taskLists.forEach(list => {
              new Sortable(list, {
                group: 'shared-tasks', // Cho phép kéo thẻ từ cột này sang cột khác
                animation: 150,
                ghostClass: 'bg-blue-100', // Hiệu ứng khi đang kéo

                // Sự kiện khi buông chuột (Kết thúc kéo)
                // project-board.js
                onEnd: async function (evt) {
                  const taskId = evt.item.getAttribute('data-id');
                  const targetColumn = evt.to.closest('.column-container');
                  const newStatus = targetColumn ? targetColumn.getAttribute('data-status') : null;

                  if (!taskId || !newStatus) return;

                  // Đẩy taskId lên URL để Middleware checkTaskPermission đọc được
                  const response = await fetch(`/api/tasks/${taskId}/update-status`, {
                    headers: {
                      'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ newStatus })
                  });

                  const data = await response.json();
                  if (response.ok) {
                    console.log("Cập nhật thành công");
                  } else {
                    alert(data.message);
                    location.reload();
                  }
                }
              });
            });
          });
        </script>

        <script>
          // Biến toàn cục từ Backend
          const currentUserIdLocal = '<%= user && user._id ? user._id : (user && user.id ? user.id : "") %>';
          const projectOwnerIdLocal = '<%= project && project.owner && project.owner._id ? project.owner._id : (project && project.owner ? project.owner : "") %>';

          document.addEventListener('DOMContentLoaded', () => {
            const txtArea = document.getElementById('txtComment');
            const btnComment = document.getElementById('btnComment');
            const addListForm = document.getElementById('addListForm');

            // --- 0. LOGIC CHO MENU LỌC (FILTER MENU) ---
            // Hàm này lồng vào window để nút bấm ở HTML gọi được
            window.toggleFilterMenu = function (e) {
              e.preventDefault();
              e.stopPropagation();
              const menu = document.getElementById('filterMenu');
              if (menu) {
                menu.classList.toggle('hidden');
              }
            };

            // Click ra ngoài để đóng menu lọc
            document.addEventListener('click', (e) => {
              const menu = document.getElementById('filterMenu');
              if (menu && !menu.contains(e.target)) {
                menu.classList.add('hidden');
              }
            });

            // 1. Khởi tạo UI cho danh sách bình luận (Chỉ inject 1 lần)
            if (txtArea && !document.getElementById('commentsList')) {
              const container = txtArea.closest('.space-y-4');
              if (container) {
                container.insertAdjacentHTML('beforeend', '<div id="commentsList" class="space-y-4 mt-6"></div>');
              }
            }

            // 2. Xử lý tạo Danh sách (Add List)
            if (addListForm) {
              addListForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const data = {
                  projectId: e.target.projectId.value,
                  title: e.target.title.value.trim()
                };
                if (!data.title) return;
                try {
                  const response = await fetch('/api/tasks/update-status', {
                    method: 'PUT',
                    headers: {
                      'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                      taskId: taskId,       // Đảm bảo tên biến là taskId
                      newStatus: newStatus  // Đảm bảo tên biến là newStatus (ví dụ: "DONE", "IN PROGRESS")
                    })
                  });
                  if (response.ok) location.reload();
                  else alert('Lỗi tạo danh sách');
                } catch (error) {
                  alert('Lỗi kết nối');
                }
              });
            }

            // 3. Xử lý gửi Bình luận
            if (btnComment && txtArea) {
              btnComment.addEventListener('click', async () => {
                const content = txtArea.value.trim();
                if (content && window.myCurrentEditingTaskId) {
                  try {
                    const response = await fetch(`/api/tasks/${window.myCurrentEditingTaskId}/comments`, {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ content })
                    });
                    if (response.ok) {
                      txtArea.value = '';
                      btnComment.disabled = true;
                      await window.loadComments(window.myCurrentEditingTaskId);
                    }
                  } catch (error) {
                    console.error('Lỗi thêm bình luận', error);
                  }
                }
              });
            }

            // 4. Gắn móc (Hook) vào hàm mở Task Detail
            if (window.openTaskDetail) {
              const originalOpenTaskDetail = window.openTaskDetail;
              window.openTaskDetail = async function (taskId) {
                window.myCurrentEditingTaskId = taskId;
                await originalOpenTaskDetail(taskId);
                await window.loadComments(taskId);
              };
            }
          });

          // --- CÁC HÀM TIỆN ÍCH (Comment & CRUD) ---
          window.loadComments = async function (taskId) {
            const commentsList = document.getElementById('commentsList');
            if (!commentsList) return;

            try {
              const response = await fetch(`/api/tasks/${taskId}/comments`);
              if (response.ok) {
                const result = await response.json();
                const comments = result.data || [];
                commentsList.innerHTML = comments.length > 0
                  ? comments.map(comment => renderCommentItem(comment)).join('')
                  : '<p class="text-center text-gray-400 text-sm">Chưa có bình luận nào.</p>';
              }
            } catch (e) {
              console.error('Lỗi tải bình luận', e);
            }
          };

          function renderCommentItem(comment) {
            const user = comment.user || comment.userId || {};
            const name = user.fullname || 'Unknown';
            const avatar = user.avatar || `https://ui-avatars.com/api/?name=${name}`;
            const date = new Date(comment.createdAt).toLocaleString('vi-VN');

            const commentUserId = String(user._id || user.id || '');
            const currentId = String(currentUserIdLocal);
            const isAuthor = currentId === commentUserId;
            const isProjectOwner = document.getElementById('projectBoardPage').getAttribute('data-is-owner') === 'true';

            return `
    <div class="flex gap-4 items-start w-full mb-4">
      <img src="${avatar}" class="w-9 h-9 rounded-full flex-shrink-0">
      <div class="w-full flex-1">
        <div class="flex items-center gap-2 mb-1">
          <span class="font-bold text-sm text-gray-900">${name}</span>
          <span class="text-xs text-gray-500">${date}</span>
        </div>
        <div id="comment-view-${comment._id}" class="group relative">
          <div class="bg-white border rounded-lg p-3 text-sm text-gray-800 shadow-sm">${comment.content}</div>
          <div class="flex gap-3 mt-1 opacity-0 group-hover:opacity-100 transition absolute top-2 right-2 bg-white/90 p-1 rounded border shadow-sm">
            ${isAuthor ? `<button onclick="editComment('${comment._id}')" class="text-xs text-blue-500 font-semibold hover:text-blue-700">Sửa</button>` : ''}
            ${(isAuthor || isProjectOwner) ? `<button onclick="deleteComment('${comment._id}')" class="text-xs text-red-500 font-semibold hover:text-red-700">Xóa</button>` : ''}
          </div>
        </div>
        <div id="comment-edit-${comment._id}" class="hidden mt-1">
          <textarea id="textarea-${comment._id}" class="w-full p-2 border rounded-lg text-sm focus:ring-2 focus:ring-blue-400 outline-none">${comment.content}</textarea>
          <div class="flex justify-end gap-2 mt-1">
            <button onclick="cancelEditComment('${comment._id}')" class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded">Hủy</button>
            <button onclick="saveEditComment('${comment._id}')" class="px-2 py-1 bg-blue-600 text-white text-xs rounded">Lưu</button>
          </div>
        </div>
      </div>
    </div>`;
          }

          window.editComment = (id) => {
            document.getElementById(`comment-view-${id}`).classList.add('hidden');
            document.getElementById(`comment-edit-${id}`).classList.remove('hidden');
          };
          window.cancelEditComment = (id) => {
            document.getElementById(`comment-view-${id}`).classList.remove('hidden');
            document.getElementById(`comment-edit-${id}`).classList.add('hidden');
          };
          window.saveEditComment = async (commentId) => {
            const content = document.getElementById(`textarea-${commentId}`).value.trim();
            if (!content) return;
            const res = await fetch(`/api/tasks/${window.myCurrentEditingTaskId}/comments/${commentId}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ content })
            });
            if (res.ok) await window.loadComments(window.myCurrentEditingTaskId);
          };
          window.deleteComment = async (commentId) => {
            if (confirm('Xóa bình luận này?')) {
              const res = await fetch(`/api/tasks/${window.myCurrentEditingTaskId}/comments/${commentId}`, { method: 'DELETE' });
              if (res.ok) await window.loadComments(window.myCurrentEditingTaskId);
            }
          };
        </script>

        <script src="/socket.io/socket.io.js"></script>
        <script>
          const socket = io();

          // SỬA LỖI TRỐNG ID: Thử lấy cả _id và id, ép về String sạch
          const rawUserId = '<%= user ? (user._id || user.id) : "" %>';
          const currentUserId = String(rawUserId).trim();

          const rawProjectId = '<%= project ? (project._id || project.id) : "" %>';
          const currentProjectId = String(rawProjectId).trim();

          // Kiểm tra ngay trên console để đảm bảo có ID trước khi kết nối Socket
          console.log("--- SOCKET CHECK ---");
          console.log("Dự án ID:", currentProjectId);
          console.log("Người dùng ID:", currentUserId);

          if (currentUserId) {
            // Tham gia phòng
            socket.emit('join-project', currentProjectId);
            socket.emit('join-personal-room', currentUserId);

            // 1. LẮNG NGHE THÔNG BÁO (HIỆN ALERT CHỐNG CHÁY)
            socket.on('notification', (data) => {
              console.log("✅ NHẬN ĐƯỢC TIN:", data);
              alert("THÔNG BÁO MỚI: " + data.content);

              // Hiện Toast sau khi bấm OK alert
              const toast = document.getElementById('socket-toast');
              const msg = document.getElementById('toast-message');
              if (toast && msg) {
                msg.innerText = data.content;
                toast.classList.remove('hidden');
                setTimeout(() => {
                  toast.classList.remove('translate-y-20');
                  toast.classList.add('translate-y-0');
                }, 100);
              }
              location.reload();
            });

            // 2. CẬP NHẬT GIAO DIỆN (AVATAR)
            socket.on('task-updated', () => {
              console.log("Board đang cập nhật...");
            });
            socket.on('task-moved', (data) => {
              console.log("✅ NHẬN ĐƯỢC TÍN HIỆU DI CHUYỂN:", data);

              // Hiện thông báo
              alert("THÔNG BÁO: " + (data.message || "Thứ tự thẻ đã thay đổi"));
            });
            socket.on('task-created', (data) => {
              console.log("Nhận tin tạo task:", data);

              // CHẶN CHÍNH MÌNH:
              if (data.senderId === currentUserId) {
                return;
              }

              // Với người khác: Hiện thông báo và reload để thấy thẻ mới
              alert("THÔNG BÁO: " + data.message);
              // location.reload();
            });
          } else {
            console.error("LỖI: Không xác định được ID người dùng để kết nối Socket!");
          }
        </script>
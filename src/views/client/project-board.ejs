<%
  const currentUserId = String(user && user.id ? user.id : (user && user._id ? user._id : ""));

  // MULTI OWNER SUPPORT
  let isOwner = false;
  if (project && project.members) {
    isOwner = project.members.some(
      m => String(m.user._id || m.user) === currentUserId && m.role === "owner"
    );
  }

  const ownerId = project && project.owner && project.owner._id
    ? String(project.owner._id)
    : String(project.owner || "");
%>

<div
  id="projectBoardPage"
  data-project-id="<%= project._id %>"
  data-is-owner="<%= isOwner %>"
  data-current-user-id="<%= currentUserId %>"
  data-owner-id="<%= ownerId %>"
  class="min-h-screen bg-gray-100 p-6"
>

  <%- include('../partials/project-board-header', { project, user, isOwner }) %>

  <%- include('../partials/project-board-columns', {
      project,
      taskLists,
      tasks,
      isOwner
  }) %>

</div>

<%- include('../partials/project-invite-modal', {
  project,
  user,
  isOwner,
  currentUserId,
  ownerId
}) %>

<%- include('../partials/task-detail-modal') %>
<%- include('../partials/date-picker-modal') %>

<!-- Trash Modal -->
<div id="trashModal" class="fixed inset-0 z-60 hidden items-center justify-center bg-black/50 p-4 backdrop-blur-sm" onclick="if(event.target === this) closeTrashModal()">
  <div class="w-full max-w-4xl bg-white rounded-2xl shadow-2xl overflow-hidden">

    <div class="flex items-center justify-between p-5 border-b border-gray-200">
      <div>
        <h3 class="text-lg font-semibold text-gray-900">Task đã xóa</h3>
        <p class="text-sm text-gray-500">
          Danh sách các task đã xóa trong dự án này
        </p>
      </div>

      <button type="button"
        onclick="event.stopPropagation(); closeTrashModal()"
        class="text-gray-500 hover:text-gray-800">
        ✕
      </button>
    </div>

    <div class="p-5">
      <div id="trashTaskList"
        class="space-y-3 max-h-96 overflow-y-auto">
      </div>
    </div>

  </div>
</div>

<style>
::-webkit-scrollbar {
  height: 8px;
  width: 8px;
}

::-webkit-scrollbar-track {
  background: #e2e8f0;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

.ghost-card {
  opacity: 0.1;
  background: #3b82f6 !important;
  border: 2px dashed #2563eb !important;
}
</style>

<link rel="stylesheet" href="/css/project-board.css">

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

<script src="/js/project-board.js"></script>

<script>

// Backend variables
const currentUserIdLocal = '<%= user && user._id ? user._id : (user && user.id ? user.id : "") %>';

const projectOwnerIdLocal = '<%= project && project.owner && project.owner._id ? project.owner._id : (project && project.owner ? project.owner : "") %>';

document.addEventListener('DOMContentLoaded', () => {

  const txtArea = document.getElementById('txtComment');

  if (txtArea) {
    const container = txtArea.closest('.space-y-4');

    if (container) {
      container.insertAdjacentHTML(
        'beforeend',
        '<div id="commentsList" class="space-y-4 mt-6"></div>'
      );
    }
  }

  const addListForm = document.getElementById('addListForm');

  if (addListForm) {
    addListForm.addEventListener('submit', async (e) => {

      e.preventDefault();

      const form = e.target;

      const data = {
        projectId: form.projectId.value,
        title: form.title.value.trim()
      };

      if (!data.title) return;

      try {

        const response = await fetch('/api/tasklists/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          location.reload();
        } else {
          alert('Lỗi tạo danh sách');
        }

      } catch (error) {
        alert('Lỗi tạo danh sách');
      }

    });
  }

  const btnComment = document.getElementById('btnComment');

  if (btnComment && txtArea) {

    btnComment.addEventListener('click', async () => {

      const content = txtArea.value.trim();

      if (content.length && window.myCurrentEditingTaskId) {

        try {

          const response = await fetch(
            `/api/tasks/${window.myCurrentEditingTaskId}/comments`,
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ content })
            }
          );

          if (response.ok) {

            txtArea.value = '';
            btnComment.disabled = true;

            await loadComments(window.myCurrentEditingTaskId);
          }

        } catch (error) {
          console.error('Lỗi thêm bình luận', error);
        }

      }

    });

  }

  if (window.openTaskDetail) {

    const originalOpenTaskDetail = window.openTaskDetail;

    window.openTaskDetail = async function(taskId) {

      window.myCurrentEditingTaskId = taskId;

      await originalOpenTaskDetail(taskId);

      await loadComments(taskId);

    };

  }

});

</script>
<div class="min-h-screen bg-gray-50 p-6">
  <div class="max-w-7xl mx-auto mb-8 flex justify-between items-center">
    <div>
      <nav class="flex text-sm text-gray-500 mb-2">
        <a href="/api/projects" class="hover:text-blue-600">Dự án</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800 font-medium"><%= project.title %></span>
      </nav>
      <h1 class="text-3xl font-extrabold text-gray-900"><%= project.title %></h1>
    </div>
  </div>

  <div class="flex gap-6 overflow-x-auto pb-6 items-start">
    <% const columns = [
        { id: 'ToDo', name: 'To Do', color: 'bg-red-500' },
        { id: 'InProgress', name: 'In Progress', color: 'bg-yellow-500' },
        { id: 'Done', name: 'Done', color: 'bg-green-500' }
    ]; %>

    <% columns.forEach(column => { %>
      <div class="w-80 flex-shrink-0 bg-gray-100 rounded-xl shadow-sm border border-gray-200">
        <div class="p-4 flex justify-between items-center">
          <div class="flex items-center gap-2">
            <div class="w-2 h-6 <%= column.color %> rounded-full"></div>
            <h2 class="font-bold text-gray-700 uppercase text-sm tracking-wider"><%= column.name %></h2>
          </div>
        </div>

        <div id="<%= column.id %>" class="task-list p-2 space-y-3 min-h-[150px]">
          <% (tasks || []).filter(t => t.status === column.id).forEach(task => { %>
            <div data-id="<%= task._id %>" class="task-item bg-white p-4 rounded-lg shadow-sm border border-transparent hover:border-blue-400 cursor-grab active:cursor-grabbing transition group relative">
              
              <button onclick="deleteTask('<%= task._id %>')" class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 text-gray-300 hover:text-red-500 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>

              <p class="text-sm text-gray-800 font-medium mb-3 pr-4"><%= task.title %></p>
              
              <div class="flex justify-between items-center">
                <span class="text-[10px] text-gray-400">🕒 <%= new Date(task.createdAt).toLocaleDateString("vi-VN") %></span>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="p-2">
          <details class="group">
            <summary class="list-none cursor-pointer p-2 text-gray-500 hover:bg-gray-200 rounded-lg flex items-center gap-2 text-sm font-medium">
              <span>+</span> Thêm một thẻ
            </summary>
            <div class="mt-2 bg-white p-3 rounded-lg shadow-md border border-blue-200">
              <form action="/api/tasks/create" method="POST" class="space-y-3">
                <input type="hidden" name="projectId" value="<%= project._id %>">
                <input type="hidden" name="status" value="<%= column.id %>">
                <textarea name="content" required class="w-full p-2 text-sm border border-gray-200 rounded outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                <button type="submit" class="bg-blue-600 text-white px-3 py-1.5 rounded text-xs font-bold">Thêm thẻ</button>
              </form>
            </div>
          </details>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
  // 1. Logic Drag & Drop (Giữ nguyên)
  const lists = document.querySelectorAll('.task-list');
  lists.forEach(list => {
    new Sortable(list, {
      group: 'kanban',
      animation: 150,
      onEnd: async function (evt) {
        const taskId = evt.item.getAttribute('data-id');
        const newStatus = evt.to.id;
        if (evt.from !== evt.to) {
          await fetch('/api/tasks/update-status', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ taskId, newStatus })
          });
        }
      }
    });
  });

  // 2. Logic XÓA TASK
  async function deleteTask(taskId) {
    if (confirm('Bạn có chắc chắn muốn xóa công việc này không?')) {
      try {
        const response = await fetch(`/api/tasks/${taskId}`, {
          method: 'DELETE',
        });

        if (response.ok) {
          // Xóa phần tử khỏi giao diện ngay lập tức mà không cần reload
          const taskElement = document.querySelector(`[data-id="${taskId}"]`);
          taskElement.style.transform = 'scale(0.8)';
          taskElement.style.opacity = '0';
          setTimeout(() => taskElement.remove(), 200);
        } else {
          alert('Lỗi khi xóa task!');
        }
      } catch (error) {
        console.error('Lỗi:', error);
      }
    }
  }
</script>

<style>
  /* Ẩn thanh cuộn mặc định để nhìn đẹp hơn */
  ::-webkit-scrollbar {
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>

<%
  const currentUserId = String(user && user.id ? user.id : (user && user._id ? user._id : ""));
  const ownerId = String(project && project.owner && project.owner._id ? project.owner._id : project.owner);
  const isOwner = currentUserId === ownerId;
%>

<div
  id="projectBoardPage"
  data-project-id="<%= project._id %>"
  data-is-owner="<%= isOwner %>"
  data-current-user-id="<%= currentUserId %>"
  data-owner-id="<%= ownerId %>"
  class="min-h-screen bg-gray-100 p-6"
>
  <%- include('../partials/project-board-header', { project, user, isOwner }) %>
  <%- include('../partials/project-board-columns', { project, taskLists, tasks, isOwner }) %>
</div>

<%- include('../partials/project-invite-modal', { project, user, isOwner, currentUserId, ownerId }) %>
<%- include('../partials/task-detail-modal') %>
<%- include('../partials/date-picker-modal') %>

      <div class="p-6 flex-grow overflow-y-auto grid grid-cols-1 md:grid-cols-[1fr,240px] gap-8">
          <div class="space-y-8">
              <div class="flex flex-wrap gap-2 pt-1">
                  <button class="flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded text-sm font-medium transition"><span class="text-lg">+</span> Thêm</button>
                  <button class="flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded text-sm font-medium transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg> Nhãn</button>
                  <button id="btnDate" class="flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded text-sm font-medium transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> <span id="btnDateText">Ngày</span></button>
              </div>

              <div class="space-y-3">
                  <div class="flex justify-between items-center">
                      <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-3">
                        <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg> Mô tả
                      </h3>
                      <button id="btnEditDesc" class="text-sm font-medium text-gray-600 bg-gray-200 hover:bg-gray-300 px-3 py-1.5 rounded transition">Sửa</button>
                  </div>
                  <div id="descView" class="p-4 bg-gray-200 rounded-lg hover:bg-gray-300 cursor-pointer min-h-[80px] transition" onclick="toggleEditDesc()">
                      <p id="txtDesc" class="text-sm text-gray-700">Thêm mô tả chi tiết hơn...</p>
                  </div>
                  <div id="descEdit" class="hidden space-y-3">
                      <textarea id="modalTaskDesc" class="w-full p-4 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none min-h-[150px] text-sm text-gray-800 transition shadow-inner" placeholder="Thêm mô tả chi tiết hơn..."></textarea>
                      <div class="flex items-center gap-2">
                          <button onclick="saveDescription()" class="px-4 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded transition shadow">Lưu</button>
                          <button onclick="cancelEditDesc()" class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 rounded transition">Hủy</button>
                      </div>
                  </div>
              </div>

              <div class="space-y-4">
                  <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-3 mb-2">
                    <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg> Hoạt động & Bình luận
                  </h3>
                  <div class="flex gap-4 items-start pt-2">
                      <img src="https://ui-avatars.com/api/?name=Admin" class="w-9 h-9 rounded-full flex-shrink-0">
                      <div class="w-full bg-white border border-gray-200 rounded-xl shadow-sm focus-within:ring-2 focus-within:ring-blue-300 transition-all overflow-hidden">
                          <textarea id="txtComment" class="w-full p-3 bg-transparent text-sm outline-none resize-none" placeholder="Viết bình luận..." rows="1"></textarea>
                          <div class="px-3 pb-2 flex justify-end">
                            <button id="btnComment" class="px-3 py-1 text-xs font-bold text-gray-500 bg-gray-100 rounded transition cursor-not-allowed" disabled>Bình luận</button>
                          </div>
                      </div>
                  </div>
              </div>
          </div>

          <div class="hidden md:block space-y-4 pt-1">
              <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Hành động</h4>
              <button class="w-full flex items-center gap-2.5 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2.5 rounded text-sm font-medium transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg> Thành viên</button>
              <button onclick="event.stopPropagation(); deleteTask(currentEditingTaskId)" class="w-full flex items-center gap-2.5 bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2.5 rounded text-sm font-semibold transition mt-4"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg> Xóa thẻ</button>
          </div>
      </div>
  </div>
</div>

<!-- Date Picker Popup -->
<div id="datePickerModal" class="fixed inset-0 bg-black/60 z-50 hidden flex items-center justify-center p-4 backdrop-blur-sm" onclick="if(event.target === this) closeDatePicker()">
  <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-md">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Chọn ngày hết hạn</h3>
    <p id="currentDeadlineText" class="text-sm text-gray-600 mb-3 hidden"></p>
    <input type="date" id="dateInput" class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
    <div class="flex items-center gap-2 mt-4">
      <button onclick="saveDeadline()" class="bg-blue-600 text-white px-4 py-2 rounded font-bold hover:bg-blue-700 transition">Lưu</button>
      <button onclick="closeDatePicker()" class="text-gray-500 hover:text-gray-800 transition px-4 py-2">Hủy</button>
<%- include('../partials/project-invite-modal', { project, user, isOwner, currentUserId, ownerId }) %>
<%- include('../partials/task-detail-modal', { project, user, isOwner, currentUserId, ownerId }) %>
<%- include('../partials/date-picker-modal') %>

<!-- Trash Modal -->
<div id="trashModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" onclick="if(event.target === this) closeTrashModal()">
  <div class="w-full max-w-4xl bg-white rounded-2xl shadow-2xl overflow-hidden">
    <div class="flex items-center justify-between p-5 border-b border-gray-200">
      <div>
        <h3 class="text-lg font-semibold text-gray-900">Task đã xóa</h3>
        <p class="text-sm text-gray-500">Danh sách các task đã xóa trong dự án này</p>
      </div>
      <button type="button" onclick="event.stopPropagation(); closeTrashModal()" class="text-gray-500 hover:text-gray-800">
        ✕
      </button>
    </div>

    <div class="p-5">
      <div id="trashTaskList" class="space-y-3 max-h-96 overflow-y-auto">
        <!-- Tasks will be loaded here -->
      </div>
    </div>
  </div>
</div>

<style>
  ::-webkit-scrollbar { height: 8px; width: 8px; }
  ::-webkit-scrollbar-track { background: #e2e8f0; border-radius: 10px; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
  .ghost-card { opacity: 0.1; background: #3b82f6 !important; border: 2px dashed #2563eb !important; }
</style>

<link rel="stylesheet" href="/css/project-board.css">
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
<script src="/js/project-board.js"></script>

<script>
  // Add backend variables for comments integration safely using existing local values 
  const currentUserIdLocal = '<%= user && user._id ? user._id : (user && user.id ? user.id : "") %>';
  const projectOwnerIdLocal = '<%= project && project.owner && project.owner._id ? project.owner._id : (project && project.owner ? project.owner : "") %>';

  document.addEventListener('DOMContentLoaded', () => {
    // 1. Inject missing comment UI structure exactly where the original feature expected it
    const txtArea = document.getElementById('txtComment');
    if (txtArea) {
      const container = txtArea.closest('.space-y-4');
      if (container) {
        container.insertAdjacentHTML('beforeend', '<div id="commentsList" class="space-y-4 mt-6"></div>');
      }
    }

    // 2. Retain Add List Form Handler
    const addListForm = document.getElementById('addListForm');
    if (addListForm) {
      addListForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const data = {
          projectId: form.projectId.value,
          title: form.title.value.trim()
        };
        if (!data.title) return;
        try {
          const response = await fetch('/api/tasklists/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (response.ok) {
            location.reload(); 
          } else {
            alert('Lỗi tạo danh sách');
          }
        } catch (error) {
          alert('Lỗi tạo danh sách');
        }
      });
    }

    // 3. Retain Comment Submit logic
    const btnComment = document.getElementById('btnComment');
    if (btnComment && txtArea) {
      btnComment.addEventListener('click', async () => {
        const content = txtArea.value.trim();
        const hasContent = content.length > 0;
        if (hasContent && window.myCurrentEditingTaskId) {
          try {
            const response = await fetch(`/api/tasks/${window.myCurrentEditingTaskId}/comments`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ content })
            });
            const isOk = response.ok;
            if (isOk) {
              txtArea.value = '';
              btnComment.disabled = true;
              btnComment.classList.remove('bg-blue-600', 'text-white');
              btnComment.classList.add('cursor-not-allowed');
              await loadComments(window.myCurrentEditingTaskId);
            }
          } catch (error) {
            console.error('Lỗi thêm bình luận', error);
          }
        }
      });
    }

    // 4. Hook the existing openTaskDetail to trigger comment load
    if (window.openTaskDetail) {
      const originalOpenTaskDetail = window.openTaskDetail;
      window.openTaskDetail = async function(taskId) {
        window.myCurrentEditingTaskId = taskId; // capture for script scope
        await originalOpenTaskDetail(taskId);
        await loadComments(taskId);
      };
    }
  });

  // Retained localized Comment API Integration Functions
  window.loadComments = async function(taskId) {
    try {
      const response = await fetch(`/api/tasks/${taskId}/comments`);
      const isOk = response.ok;
      if (isOk) {
        const result = await response.json();
        const comments = result.data || result;
        const hasComments = comments && comments.length > 0;
        const commentsList = document.getElementById('commentsList');
        if(!commentsList) return;
        commentsList.innerHTML = '';
        if (hasComments) {
          comments.forEach(comment => {
            const user = comment.user || comment.userId || {};
            const name = user.fullname || 'Unknown';
            const avatar = user.avatar || `https://ui-avatars.com/api/?name=${name}`;
            const date = new Date(comment.createdAt).toLocaleString('vi-VN');
            
            const commentUserId = user._id || user.id || '';
            const isAuthor = currentUserIdLocal === commentUserId;
            const isProjectOwner = currentUserIdLocal === projectOwnerIdLocal;
            const canEdit = isAuthor;
            const canDelete = isAuthor || isProjectOwner;

            let editBtnHtml = '';
            if (canEdit) {
              editBtnHtml = `<button onclick="editComment('${comment._id}')" class="text-xs text-blue-500 font-semibold hover:underline">Sửa</button>`;
            }

            let deleteBtnHtml = '';
            if (canDelete) {
              deleteBtnHtml = `<button onclick="deleteComment('${comment._id}')" class="text-xs text-red-500 font-semibold hover:underline">Xóa</button>`;
            }

            const html = `
              <div class="flex gap-4 items-start w-full">
                <img src="${avatar}" class="w-9 h-9 rounded-full flex-shrink-0" title="${name}">
                <div class="w-full flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-bold text-sm text-gray-900 truncate">${name}</span>
                    <span class="text-xs text-gray-500 flex-shrink-0">${date}</span>
                  </div>
                  
                  <div id="comment-view-${comment._id}" class="group relative">
                    <div class="bg-white border border-gray-200 rounded-lg p-3 text-sm text-gray-800 shadow-sm whitespace-pre-wrap break-words">${comment.content}</div>
                    <div class="flex gap-3 mt-1 opacity-0 group-hover:opacity-100 transition absolute top-2 right-2 bg-white/90 p-1 rounded backdrop-blur border border-gray-100 shadow-sm">
                      ${editBtnHtml}
                      ${deleteBtnHtml}
                    </div>
                  </div>

                  <div id="comment-edit-${comment._id}" class="hidden mt-1 bg-white border border-blue-400 rounded-xl overflow-hidden focus-within:ring-2 focus-within:ring-blue-300 transition-all shadow-sm">
                    <textarea id="textarea-${comment._id}" class="w-full p-3 text-sm outline-none resize-none min-h-[60px] bg-transparent">${comment.content}</textarea>
                    <div class="px-3 pb-2 flex justify-end gap-2">
                      <button onclick="cancelEditComment('${comment._id}')" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600 font-bold text-xs rounded transition">Hủy</button>
                      <button onclick="saveEditComment('${comment._id}')" class="px-4 py-1.5 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded transition shadow">Lưu</button>
                    </div>
                  </div>
                </div>
              </div>
            `;
            commentsList.insertAdjacentHTML('beforeend', html);
          });
        }
      }
    } catch (e) {
      console.error('Lỗi tải bình luận', e);
    }
  };

  window.editComment = function(commentId) {
    document.getElementById(`comment-view-${commentId}`).classList.add('hidden');
    document.getElementById(`comment-edit-${commentId}`).classList.remove('hidden');
    document.getElementById(`textarea-${commentId}`).focus();
  };

  window.cancelEditComment = function(commentId) {
    document.getElementById(`comment-view-${commentId}`).classList.remove('hidden');
    document.getElementById(`comment-edit-${commentId}`).classList.add('hidden');
  };

  window.saveEditComment = async function(commentId) {
    const textarea = document.getElementById(`textarea-${commentId}`);
    const content = textarea.value.trim();
    const hasContent = content.length > 0;
    if (hasContent && window.myCurrentEditingTaskId) {
      try {
        const response = await fetch(`/api/tasks/${window.myCurrentEditingTaskId}/comments/${commentId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content })
        });
        const isOk = response.ok;
        if (isOk) {
          await loadComments(window.myCurrentEditingTaskId);
        } else {
          alert('Lỗi sửa bình luận');
        }
      } catch (e) {
        console.error(e);
      }
    }
  };

  window.deleteComment = async function(commentId) {
    const isConfirm = confirm('Bạn có chắc muốn xóa bình luận này?');
    if (isConfirm && window.myCurrentEditingTaskId) {
      try {
        const response = await fetch(`/api/tasks/${window.myCurrentEditingTaskId}/comments/${commentId}`, {
          method: 'DELETE'
        });
        const isOk = response.ok;
        if (isOk) {
          await loadComments(window.myCurrentEditingTaskId);
        } else {
          alert('Lỗi xóa bình luận');
        }
      } catch (e) {
        console.error(e);
      }
    }
  };
</script>

<div class="bg-white p-8 rounded-lg shadow-xl border border-gray-100 w-full max-w-md mx-auto">
    <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-gray-800 tracking-tight">Tạo tài khoản</h2>
        <p class="text-gray-500 text-sm">Cùng xây dựng dự án với TaskFlow</p>
    </div>

    <% if (error) { %>
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-3 mb-4 text-sm rounded shadow-sm">
            <%= error %>
        </div>
        <% } %>

            <form action="/auth/register" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-600 mb-1">Họ và tên</label>
                    <input type="text" name="fullname" required
                        class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                        placeholder="Ví dụ: Nguyễn Anh Tú">
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-600 mb-1">Email</label>
                    <input type="email" name="email" required
                        class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                        placeholder="email@example.com">
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-600 mb-1">Mật khẩu</label>
                    <input type="password" name="password" required minlength="6"
                        class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                        placeholder="Tối thiểu 6 ký tự">
                </div>

                <button type="submit"
                    class="w-full bg-blue-700 hover:bg-blue-800 text-white font-bold py-2.5 rounded shadow-md transition duration-200 mt-2">
                    Đăng ký
                </button>
            </form>

            <div class="mt-6 pt-6 border-t border-gray-100 text-center text-sm text-gray-600">
                Đã có tài khoản?
                <a href="/auth/login" class="text-blue-700 hover:underline font-bold">Đăng nhập ngay</a>
            </div>
</div>
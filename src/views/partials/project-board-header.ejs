<div class="max-w-7xl mx-auto mb-8 flex justify-between items-start gap-4">
  <div>
    <nav class="flex text-sm text-gray-500 mb-2">
      <a href="/" class="hover:text-blue-600">Dự án</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800 font-medium"><%= project.title %></span>
    </nav>

    <h1 class="text-3xl font-extrabold text-gray-900"><%= project.title %></h1>

    <% if (project.description) { %>
      <p class="text-sm text-gray-500 mt-2 max-w-2xl"><%= project.description %></p>
    <% } %>
  </div>

  <div class="flex items-center gap-3 flex-wrap justify-end">
    <div class="flex -space-x-2">
      <% (project.members || []).forEach(memberItem => { %>
        <% const member = memberItem && memberItem.user ? memberItem.user : memberItem; %>
        <img
          src="<%= member.avatar || ('https://ui-avatars.com/api/?name=' + encodeURIComponent(member.fullname || 'User')) %>"
          class="h-8 w-8 rounded-full border-2 border-white object-cover"
          title="<%= member.fullname %>"
        >
      <% }) %>
    </div>

    <% if (isOwner) { %>
      <button
        type="button"
        onclick="openInviteModal()"
        class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-bold transition shadow-md"
      >
        Mời thành viên
      </button>

      <button
        type="button"
        onclick="openTrashModal()"
        class="bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2 rounded-lg text-sm font-bold transition shadow-md"
        title="Xem task đã xóa"
      >
        🗑️
      </button>

      <details class="relative">
        <summary class="list-none bg-white hover:bg-gray-50 text-gray-800 border border-gray-200 px-4 py-2 rounded-lg text-sm font-bold transition shadow-sm cursor-pointer">
          Quản lý dự án
        </summary>

        <div class="absolute top-full mt-2 right-0 bg-white p-4 rounded-xl shadow-xl border border-gray-200 z-20 min-w-[340px]">
          <form action="/api/projects/<%= project._id %>?_method=PATCH" method="POST" class="space-y-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tên project</label>
              <input
                type="text"
                name="title"
                value="<%= project.title %>"
                required
                class="w-full p-3 text-sm border border-gray-200 rounded-lg outline-none focus:ring-2 focus:ring-blue-500"
              >
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Mô tả</label>
              <textarea
                name="description"
                rows="3"
                class="w-full p-3 text-sm border border-gray-200 rounded-lg outline-none focus:ring-2 focus:ring-blue-500"
              ><%= project.description || "" %></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg text-sm font-bold transition"
            >
              Cập nhật thông tin
            </button>
          </form>

          <form
            action="/api/projects/<%= project._id %>?_method=DELETE"
            method="POST"
            class="mt-3"
            onsubmit="return confirm('Bạn có chắc muốn xóa project này?')"
          >
            <button
              type="submit"
              class="w-full border border-red-200 text-red-600 hover:bg-red-50 py-2 rounded-lg text-sm font-bold transition"
            >
              Xóa project
            </button>
          </form>
        </div>
      </details>

      <details class="relative">
        <summary class="list-none bg-gray-700 hover:bg-gray-800 text-white px-4 py-2 rounded-lg text-sm font-bold transition shadow-md cursor-pointer">
          Thêm danh sách khác
        </summary>

        <div class="absolute top-full mt-2 right-0 bg-white p-4 rounded-lg shadow-lg border border-gray-200 z-10 min-w-[260px]">
          <form action="/api/tasklists/create" method="POST" class="space-y-3">
            <input type="hidden" name="projectId" value="<%= project._id %>">
            <input
              type="text"
              name="title"
              required
              placeholder="Tên danh sách..."
              class="w-full p-3 text-sm border border-gray-200 rounded-lg outline-none focus:ring-2 focus:ring-blue-500 shadow-inner"
            >
            <div class="flex items-center gap-2">
              <button
                type="submit"
                class="bg-blue-600 text-white px-4 py-2 rounded font-bold text-xs hover:bg-blue-700 transition"
              >
                Lưu
              </button>
              <button
                type="button"
                onclick="this.closest('details').open = false"
                class="text-gray-500 hover:text-gray-800 transition p-1"
              >
                Hủy
              </button>
            </div>
          </form>
        </div>
      </details>
    <% } %>
  </div>
</div>
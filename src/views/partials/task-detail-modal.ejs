<div
  id="taskModal"
  class="fixed inset-0 bg-black/60 z-50 hidden items-center justify-center p-4 backdrop-blur-sm"
  onclick="if(event.target === this) closeModal()"> 

  <div class="bg-[#F4F5F7] rounded-xl shadow-2xl w-full max-w-4xl overflow-hidden border border-gray-100 max-h-[90vh] flex flex-col text-left">
    <div class="p-6 pb-2 flex justify-between items-start">
      <div class="flex gap-4 items-start w-full">
        <svg class="w-6 h-6 text-gray-600 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
        </svg>

        <div class="w-full">
          <input
            type="text"
            id="modalTaskTitle"
            class="w-full text-2xl font-bold text-gray-900 bg-transparent p-1 -ml-1 rounded hover:bg-gray-200 focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition"
            value="Loading..."
          >
          <p class="text-sm text-gray-600 mt-1">
            trong danh sách
            <span id="modalColumnName" class="font-medium text-gray-700 underline">...</span>
          </p>
          <p id="modalDeadlineText" class="text-sm text-gray-600 mt-1 hidden"></p>
          <div id="modalAssigneeList" class="mt-3 flex flex-wrap items-center gap-2"></div>
        </div>
      </div>

      <button
        type="button"
        onclick="closeModal()"
        class="text-gray-500 hover:text-gray-800 transition p-2 hover:bg-gray-200 rounded-full flex-shrink-0 -mt-2 -mr-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="p-6 flex-grow overflow-y-auto grid grid-cols-1 md:grid-cols-[1fr,240px] gap-8">
      <div class="space-y-8">
        <div class="flex flex-wrap gap-2 pt-1">
          <% if (isOwner) { %>
          <button
            type="button"
            onclick="openAssignPopup(event)"
            class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-medium transition"
          >
            <span class="text-lg">+</span> Gán thành viên
          </button>
          <% } %>

          <button
            type="button"
            class="flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded text-sm font-medium transition"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
            </svg>
            Nhãn
          </button>

          <% if (isOwner) { %>
          <button
            type="button"
            id="btnDate"
            onclick="openDatePicker()"
            class="flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded text-sm font-medium transition"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span id="btnDateText">Ngày</span>
          </button>
          <% } %>
        </div>

        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-3">
              <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
              </svg>
              Mô tả
            </h3>

            <button
              type="button"
              id="btnEditDesc"
              class="text-sm font-medium text-gray-600 bg-gray-200 hover:bg-gray-300 px-3 py-1.5 rounded transition"
              onclick="toggleEditDesc()"
            >
              Sửa
            </button>
          </div>

          <div
            id="descView"
            class="p-4 bg-gray-200 rounded-lg hover:bg-gray-300 cursor-pointer min-h-[80px] transition"
            onclick="toggleEditDesc()"
          >
            <p id="txtDesc" class="text-sm text-gray-700">Thêm mô tả chi tiết hơn...</p>
          </div>

          <div id="descEdit" class="hidden space-y-3">
            <textarea
              id="modalTaskDesc"
              class="w-full p-4 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none min-h-[150px] text-sm text-gray-800 transition shadow-inner"
              placeholder="Thêm mô tả chi tiết hơn..."
            ></textarea>

            <div class="flex items-center gap-2">
              <button
                type="button"
                onclick="saveDescription()"
                class="px-4 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded transition shadow"
              >
                Lưu
              </button>

              <button
                type="button"
                onclick="cancelEditDesc()"
                class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 rounded transition"
              >
                Hủy
              </button>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-3 mb-2">
            <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            Hoạt động & Bình luận
          </h3>

          <div class="flex gap-4 items-start pt-2">
            <img src="https://ui-avatars.com/api/?name=Admin" class="w-9 h-9 rounded-full flex-shrink-0">

            <div class="w-full bg-white border border-gray-200 rounded-xl shadow-sm focus-within:ring-2 focus-within:ring-blue-300 transition-all overflow-hidden">
              <textarea
                id="txtComment"
                class="w-full p-3 bg-transparent text-sm outline-none resize-none"
                placeholder="Viết bình luận..."
                rows="1"
              ></textarea>

              <div class="px-3 pb-2 flex justify-end">
                <button
                  type="button"
                  id="btnComment"
                  class="px-3 py-1 text-xs font-bold text-gray-500 bg-gray-100 rounded transition cursor-not-allowed"
                  disabled
                >
                  Bình luận
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div id="assignMemberPopup" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" onclick="if(event.target === this) closeAssignPopup()">
        <div class="w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden">
          <div class="flex items-center justify-between p-5 border-b border-gray-200">
            <div>
              <h3 class="text-lg font-semibold text-gray-900">Chọn thành viên</h3>
              <p class="text-sm text-gray-500">Tìm theo tên hoặc email để gán vào task</p>
            </div>
            <button type="button" onclick="event.stopPropagation(); closeAssignPopup()" class="text-gray-500 hover:text-gray-800">
              ✕
            </button>
          </div>

          <div class="p-5 space-y-4">
            <div class="rounded-lg border border-gray-200 overflow-hidden">
              <input id="assignSearchInput" type="text" placeholder="Tìm kiếm theo tên hoặc email" class="w-full p-3 text-sm outline-none" oninput="filterAssignMembers()" />
            </div>

            <div id="assignMemberList" class="max-h-80 overflow-y-auto space-y-2"></div>
          </div>
        </div>
      </div>

      <div class="hidden md:block space-y-4 pt-1">
        <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Hành động</h4>

        <button
          type="button"
          class="w-full flex items-center gap-2.5 bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2.5 rounded text-sm font-medium transition"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          Thành viên
        </button>

        <% if (isOwner) { %>
        <button
          type="button"
          onclick="event.stopPropagation(); deleteTask(currentEditingTaskId)"
          class="w-full flex items-center gap-2.5 bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2.5 rounded text-sm font-semibold transition mt-4"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Xóa thẻ
        </button>
        <% } %>
      </div>
    </div>
  </div>
</div>